[project]
sub_id = "5bc85707"
name = "projects"
requires = ["nodejs-24", "python-3.12"]
project_type = "web"

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "projects/projects/2026海关公示/scripts/coze-preview-build.sh"]
run = ["bash", "projects/projects/2026海关公示/scripts/coze-preview-run.sh"]

[deploy]
build = ["bash", "projects/projects/2026海关公示/scripts/coze-deploy-build.sh"]
run = ["bash", "projects/projects/2026海关公示/scripts/coze-deploy-run.sh"]

[deploy.profile]
kind = "service"
flavor = "web"

[subprojects]
path = ["projects/projects/2026海关公示"]
